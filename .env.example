# ─── Vault (bootstrap only — real secrets live in Vault) ──────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-only-root-token

# ─── Service ports (host side) ────────────────────────────────────
API_PORT=8000
ADMIN_PORT=8501
WIDGET_PORT=8081
HOST_PORT=8080
LANGFUSE_PORT=3001

# ─── Infra ports (host side) ──────────────────────────────────────
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
VAULT_PORT=8200

# ─── Vault path prefix (KV v2 paths live under secret/<prefix>/*) ──
VAULT_KV_PATH_PREFIX=maintainer-copilot

# ─── Anthropic API key (forwarded to vault-init for seeding) ──────
# Replace with your real key locally. NEVER commit a real key.
ANTHROPIC_API_KEY=sk-ant-dev-placeholder-replace-in-vault

# ─── Langfuse API keys (forwarded to vault-init for seeding) ───────
# Get from the Langfuse UI at http://localhost:3001 → Settings → API Keys.
# NEVER commit real keys.
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder-replace-after-first-boot
LANGFUSE_SECRET_KEY=sk-lf-placeholder-replace-after-first-boot

# ─── GitHub API token (dataset fetch — public read-only is enough) ──
# Generate at https://github.com/settings/tokens?type=beta
# Public repository read access is sufficient. NEVER commit a real token.
GITHUB_TOKEN=ghp_placeholder-generate-at-github-settings-tokens